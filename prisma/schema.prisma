generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

model Agence {
  id                    Int                   @id @default(autoincrement())
  nom_agence            String
  code_agence           String                @unique
  ville                 String
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  archive               Boolean               @default(false)
  archivedAt            DateTime?
  pointService          PointDeService[]
  users                 User[]
  mouvementsSource      MouvementEquipement[] @relation("MouvementAgenceSource")
  mouvementsDestination MouvementEquipement[] @relation("MouvementAgenceDest")
  equipementsActuels    Equipement[]          @relation("EquipementAgenceActuelle")

}

model Poste {
  id         Int       @id @default(autoincrement())
  nom        String    @unique
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  archive    Boolean   @default(false)
  archivedAt DateTime?
  users      User[]
}

model User {
  id                    Int                   @id @default(autoincrement())
  nom                   String
  prenom                String
  username              String                @unique
  email                 String                @unique
  password              String
  code_identifiant      String                @unique
  agenceId              Int
  posteId               Int
  chefId                Int?
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  archive               Boolean               @default(false)
  archivedAt            DateTime?
  mouvementsInitie      MouvementEquipement[] @relation("MouvementInitiateur")
  mouvementsConfirmes   MouvementEquipement[] @relation("MouvementConfirmePar")
  mouvementsResponsableSource MouvementEquipement[] @relation("MouvementResponsableSource")
  mouvementsResponsableDest   MouvementEquipement[] @relation("MouvementResponsableDest")
  equipementsActuels     Equipement[]        @relation("EquipementResponsableActuel")
  notifications          Notification[]      @relation("NotificationUser")
  actionCredit       ActionCredit[]
  creditBeneficiaire Credit[] @relation("CreditBeneficiaire")
  creditAgent        Credit[] @relation("CreditAgent")
  decisions          Decision[]
  demandesAValider   Demande[]      @relation("DemandeCurrentApprover")
  demandes           Demande[]
  evenementsPublies  Evenement[]    @relation("EvenementPublieur")
  evenementsCrees    Evenement[]    @relation("EvenementCreateur")
  agence             Agence         @relation(fields: [agenceId], references: [id])
  chef               User?          @relation("ChefSubordonne", fields: [chefId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  subordonnes        User[]         @relation("ChefSubordonne")
  poste              Poste          @relation(fields: [posteId], references: [id])
  roles              UserRole[]
}

model Role {
  id              Int              @id @default(autoincrement())
  nom             String           @unique
  slug            String           @unique
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  archive         Boolean          @default(false)
  archivedAt      DateTime?
  rolePermissions RolePermission[]
  userRoles       UserRole[]
}

model UserRole {
  userId     Int
  roleId     Int
  assignedAt DateTime  @default(now())
  archive    Boolean   @default(false)
  archivedAt DateTime?
  role       Role      @relation(fields: [roleId], references: [id], onUpdate: NoAction)
  user       User      @relation(fields: [userId], references: [id], onUpdate: NoAction)

  @@id([userId, roleId])
}

model Permission {
  id              Int              @id @default(autoincrement())
  nom             String           @unique
  slug            String           @unique
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  archive         Boolean          @default(false)
  archivedAt      DateTime?
  rolePermissions RolePermission[]
}

model RolePermission {
  id           Int        @id @default(autoincrement())
  roleId       Int
  permissionId Int
  createdAt    DateTime   @default(now())
  archive      Boolean    @default(false)
  archivedAt   DateTime?
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
}


model Demande {
  id                Int       @id @default(autoincrement())

  type              String

  dateDebut         DateTime
  dateFin           DateTime
  motif             String

  status            String    @default("EN_ATTENTE")
  pdfPath           String?

  userId            Int
  currentApproverId Int?

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  archive           Boolean   @default(false)
  archivedAt        DateTime?

  decisions         Decision[]
  notifications     Notification[]

  currentApprover   User?  @relation("DemandeCurrentApprover", fields: [currentApproverId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  user              User   @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
}


model Decision {
  id         Int       @id @default(autoincrement())
  status     String
  niveau     String
  userId     Int
  demandeId  Int
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  archive    Boolean   @default(false)
  archivedAt DateTime?
  demande    Demande   @relation(fields: [demandeId], references: [id], onUpdate: NoAction)
  user       User      @relation(fields: [userId], references: [id], onUpdate: NoAction)
}

model Evenement {
  id          Int       @id @default(autoincrement())
  titre       String
  description String
  dateDebut   DateTime
  dateFin     DateTime
  images      String?   @db.NVarChar(Max)
  statut      String    @default("EN_ATTENTE")
  userId      Int
  publishedBy Int?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  archive     Boolean   @default(false)
  archivedAt  DateTime?
  publieur    User?     @relation("EvenementPublieur", fields: [publishedBy], references: [id], onDelete: NoAction, onUpdate: NoAction)
  user        User      @relation("EvenementCreateur", fields: [userId], references: [id], onUpdate: NoAction)
}

model PointDeService {
  id               Int                   @id @default(autoincrement())
  nom              String
  agenceId         Int
  agence           Agence                @relation(fields: [agenceId], references: [id], onUpdate: NoAction)
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  archive          Boolean               @default(false)
  archivedAt       DateTime?
  mouvementsSource MouvementEquipement[] @relation("MvtPSSource")
  mouvementsDest   MouvementEquipement[] @relation("MvtPSDest")
  equipementsActuels Equipement[] @relation("EquipementPointServiceActuel")
}

model Equipement {
  id              Int       @id @default(autoincrement())

  // Identification
  nom             String
  modele          String?
  images          String?   @db.NVarChar(Max)

  // Cycle de vie
  dateAcquisition DateTime  @default(now())

  // État technique
  etat            String    @default("FONCTIONNEL")
  // FONCTIONNEL | EN_PANNE | EN_REPARATION | HORS_SERVICE | EN_TRANSIT

  // Statut d’affectation
  status           String   @default("DISPONIBLE")
  // DISPONIBLE | ASSIGNE

  // Localisation actuelle
  agenceActuelleId       Int?
  pointServiceActuelId   Int?

  // Responsable actuel
  responsableActuelId   Int?

  // Métadonnées
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  archive         Boolean   @default(false)
  archivedAt      DateTime?

  mouvements          MouvementEquipement[]

  agenceActuelle      Agence?         @relation("EquipementAgenceActuelle", fields: [agenceActuelleId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  pointServiceActuel  PointDeService? @relation("EquipementPointServiceActuel", fields: [pointServiceActuelId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  responsableActuel   User?           @relation("EquipementResponsableActuel", fields: [responsableActuelId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  notifications Notification[] @relation("NotificationEquipement")
}


model MouvementEquipement {
  id Int @id @default(autoincrement())

  // Type de mouvement
  type String
  commentaire String?
  createdAt DateTime @default(now())
  etatAvant String?
  etatApres String?

  // Liens principaux
  equipementId Int
  initiateurId Int

  // Localisation source
  agenceSourceId        Int?
  pointServiceSourceId Int?

  // Localisation destination
  agenceDestinationId        Int?
  pointServiceDestinationId Int?

  // Responsables
  responsableSourceId      Int?
  responsableDestinationId Int?

  // Confirmation de réception
  confirme         Boolean   @default(false)
  confirmeParId    Int?
  dateConfirmation DateTime?

  // Relations
  equipement Equipement @relation(fields: [equipementId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  initiateur User @relation(name: "MouvementInitiateur", fields: [initiateurId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  responsableSource User? @relation(name: "MouvementResponsableSource", fields: [responsableSourceId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  responsableDestination User? @relation(name: "MouvementResponsableDest", fields: [responsableDestinationId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  confirmePar User? @relation(name: "MouvementConfirmePar", fields: [confirmeParId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  // Agences
  agenceSource Agence? @relation(name: "MouvementAgenceSource", fields: [agenceSourceId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  agenceDestination Agence? @relation(name: "MouvementAgenceDest", fields: [agenceDestinationId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  // Points de service
  pointServiceSource PointDeService? @relation(name: "MvtPSSource", fields: [pointServiceSourceId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  
  pointServiceDestination PointDeService? @relation(name: "MvtPSDest", fields: [pointServiceDestinationId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  notifications Notification[] @relation("NotificationMouvement")
}



model Credit {
  id               Int       @id @default(autoincrement())
  reference        String    @unique
  montant          Float
  montantRembourse Float     @default(0)
  tauxInteret      Float
  dateDebut        DateTime
  dateFin          DateTime
  status           String    @default("EN_COURS")
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  archive          Boolean   @default(false)
  archivedAt       DateTime?

  beneficiaireId Int
  beneficiaire   User @relation("CreditBeneficiaire", fields: [beneficiaireId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  
  agentId        Int?           // facultatif
  agent          User? @relation("CreditAgent", fields: [agentId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  actions        ActionCredit[]
  histories      CreditHistory[]
}


model ActionCredit {
  id        Int      @id @default(autoincrement())
  creditId  Int
  agentId   Int?

  type      String
  commentaire String?
  date        DateTime  @default(now())
  archive     Boolean   @default(false)
  archivedAt  DateTime?

  credit Credit @relation(fields: [creditId], references: [id], onDelete: Cascade)
  agent  User?  @relation(fields: [agentId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  notifications Notification[]
}


model CreditHistory {
  id        Int      @id @default(autoincrement())
  creditId  Int
  field     String
  oldValue  String?
  newValue  String?
  updatedAt DateTime @default(now())

  credit Credit @relation(fields: [creditId], references: [id])
}


model Notification {
  id Int @id @default(autoincrement())
  titre   String
  message String
  type    String
  canal   String @default("IN_APP")
  lu      Boolean @default(false)
  luAt    DateTime?

  userId        Int
  demandeId     Int?   // 👈 AJOUTER ICI
  equipementId  Int?
  mouvementId   Int?
  actionCreditId Int?

  createdAt DateTime @default(now())

  user        User @relation("NotificationUser", fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  demande     Demande? @relation(fields: [demandeId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  equipement  Equipement? @relation("NotificationEquipement", fields: [equipementId], references: [id])
  mouvement   MouvementEquipement? @relation("NotificationMouvement", fields: [mouvementId], references: [id])
  actionCredit ActionCredit? @relation(fields: [actionCreditId], references: [id])
}


